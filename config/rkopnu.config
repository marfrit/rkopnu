# Kernel config needed to build + run rkopnu (out-of-tree).
# The accel subsystem is the key one; enabling the in-tree rocket driver as a
# module is the simplest way to pull it in (then blacklist rocket at runtime).
CONFIG_DRM_ACCEL=y
CONFIG_DRM_ACCEL_ROCKET=m
CONFIG_DRM_SCHED=y
CONFIG_DRM_GEM_SHMEM_HELPER=y
CONFIG_ROCKCHIP_IOMMU=y
CONFIG_PM=y
CONFIG_PM_DEVFREQ=y
